# SuperadminBackend – all values from .env (no fallbacks)
NODE_ENV=development
PORT=8001
LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=superadmin_db
AUTH_DB_NAME=auth_db
DB_POOL_SIZE=10

# MongoDB (Resume template and report data)
MONGODB_URI=
MONGODB_DB_NAME=kareergrowth

# OpenAI (for AI Config in DB – run scripts/seed-ai-config-key.js to push OPENAI_API_KEY into ai_config)
OPENAI_API_KEY=

# Service URLs
ADMIN_BACKEND_URL=http://localhost:8002
AUTH_SERVICE_URL=http://localhost:8001
CANDIDATE_SERVICE_URL=http://localhost:8003
API_GATEWAY_URL=
STREAMING_SERVICE_URL=
AI_SERVICE_URL=http://localhost:9002

# Service auth
INTERNAL_SERVICE_TOKEN=your_internal_token
SERVICE_NAME=superadmin-backend
ALLOWED_SERVICES=superadmin-backend

# JWT
JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_refresh_secret
JWT_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=7
JWT_ALGORITHM=HS256

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# XSRF / Session / Login / Security (set as needed)
XSRF_TOKEN_EXPIRY_MINUTES=30
XSRF_DOUBLE_SUBMIT=false
XSRF_SECRET=
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION_MINUTES=15
LOGIN_ATTEMPT_WINDOW_MINUTES=15
SESSION_SECRET=
SESSION_MAX_AGE_MINUTES=30
SESSION_COOKIE_NAME=sessionId
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100
# Auth endpoints (login, refresh): higher limit so normal use doesn't get 429
RATE_LIMIT_AUTH_WINDOW_MINUTES=15
RATE_LIMIT_AUTH_MAX_REQUESTS=100
ENABLE_AUTH_RATE_LIMITING=true
ENABLE_AUDIT_LOGGING=false
ENABLE_LOGIN_ATTEMPT_TRACKING=true
ENABLE_XSRF_PROTECTION=true
ENABLE_RATE_LIMITING=true

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:4000,http://localhost:4001,http://localhost:4002,http://localhost:4003,http://localhost:5173,http://127.0.0.1:4000,http://127.0.0.1:4001,http://127.0.0.1:4002,http://127.0.0.1:4003

SWAGGER_SERVER_URL=http://localhost:8001
